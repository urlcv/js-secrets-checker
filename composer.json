{
    "name": "urlcv/js-secrets-checker",
    "description": "Scan front-end JavaScript for hard-coded API keys, tokens, endpoints, and sensitive strings. Powers the free JS Secrets Checker tool at urlcv.com.",
    "type": "library",
    "license": "MIT",
    "keywords": ["javascript", "secrets", "security", "api-keys", "tokens", "scanner", "frontend"],
    "homepage": "https://urlcv.com/tools/js-secrets-checker",
    "authors": [
        {
            "name": "URLCV",
            "homepage": "https://urlcv.com"
        }
    ],
    "require": {
        "php": "^8.1"
    },
    "autoload": {
        "psr-4": {
            "URLCV\\JsSecretsChecker\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "URLCV\\JsSecretsChecker\\Laravel\\JsSecretsCheckerServiceProvider"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
